# Example environment variables — do NOT commit real secrets
# 백업 또는 CI에서 사용하는 예시 환경 변수

# API keys (set only if needed for experiments; do not commit)
OPENAI_API_KEY=

# Storage / DB
DATABASE_URL=sqlite:///data/app.db

# Retrieval / embeddings
EMBEDDING_MODEL=name-of-embedding-model
RETRIEVAL_INDEX_PATH=./data/processed/index

# Experiment / logging
LOG_LEVEL=INFO
EXPERIMENT_OUTPUT_DIR=./experiments/outputs
